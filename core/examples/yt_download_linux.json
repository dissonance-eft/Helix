{
  "Task": "yt_dlp_demo",
  "Steps": [
    { "Type": "run", "Cmd": "mkdir -p downloads" },
    { "Type": "run", "Cmd": "yt-dlp -f mp4 -o 'downloads/%(title)s.%(ext)s' https://www.youtube.com/watch?v=dQw4w9WgXcQ" },
    { "Type": "validate_exists", "Path": "downloads" },
    { "Type": "checksum", "Path": "downloads", "Algo": "SHA256", "SaveAs": "downloads/download_log.sha256" },
    { "Type": "run", "Cmd": "mkdir -p build && tar -czf build/yt_archive_$(date +%F).tar.gz -C downloads ." }
  ]
}

